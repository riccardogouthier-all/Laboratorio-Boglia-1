# Copiare questo file in ".env" prima di avviare lo stack:
#   cp .env.example .env

# Host:porta del registry Docker locale usato per push/pull delle immagini.
REGISTRY_HOST=localhost:5000

# Credenziali RabbitMQ (broker + management UI)
RABBITMQ_DEFAULT_USER=musiclab
RABBITMQ_DEFAULT_PASS=musiclab_pw

# URL AMQP usato dai microservizi per connettersi al broker
RABBITMQ_URL=amqp://musiclab:musiclab_pw@rabbitmq:5672
